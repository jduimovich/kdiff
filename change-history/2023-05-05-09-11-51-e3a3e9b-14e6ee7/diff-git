+apiVersion: argoproj.io/v1alpha1
+kind: ApplicationSet
+metadata:
+  name: disable-csvcopy
+spec:
+  generators:
+    - merge:
+        mergeKeys:
+          - nameNormalized
+        generators:
+          - clusters:
+              values:
+                sourceRoot: configs/disable-csvcopy-for-all-cluster
+                environment: staging
+                clusterDir: ""
+          - list:
+              elements: []
+  template:
+    metadata:
+      name: disable-csvcopy-{{nameNormalized}}
+    spec:
+      project: default
+      source:
+        path: configs/disable-csvcopy-for-all-cluster
+        repoURL: https://github.com/redhat-appstudio/infra-deployments.git
+        targetRevision: main
+      destination:
+        server: '{{server}}'
+      syncPolicy:
+        automated:
+          prune: true
+          selfHeal: true
+        retry:
+          limit: -1
+          backoff:
+            duration: 10s
+            factor: 2
+            maxDuration: 3m
