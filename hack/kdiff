SCRIPTDIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"  
ROOT="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"/..

CACHE_DIR=$ROOT/kustomized-cache
COMPARE_DIR=$ROOT/change-history

START_TAG=$1
if [[ -z "$START_TAG" ]]; then
  echo "No start tag parameter, will use current HEAD and HEAD^ to compute diff"   
else 
  echo "Diff from $START_TAG" 
  git checkout $START_TAG   >/dev/null 2>&1
fi

function ktry() {  
    COMPONENT_DIR=$1
    TAG_DIR=$2 
    OUT_DIR=$TAG_DIR/$COMPONENT_DIR 
    OUT_FILE=$OUT_DIR/kustomize.out  
    if [ ! -f "$OUT_FILE" ]; then 
        K1=$COMPONENT_DIR 
        if [ -f "$K1/kustomization.yaml" ]; then 
            echo -n . 
            mkdir -p $OUT_DIR  
            kustomize build $K1 | cat > $OUT_FILE 
        fi  
    fi     
}

function generateManifests()  { 
    TAG=$1
    echo -n "Generating kustomize for Tag $TAG " 
    TAG_DIR=$CACHE_DIR/tag-$TAG
    mkdir -p $TAG_DIR
    APP_OF_APPS=$TAG_DIR/app-of-apps-staging.yaml 
    if [ -f "$APP_OF_APPS" ]; then 
        echo -n .
    else  
        kustomize build argo-cd-apps/overlays/staging >$APP_OF_APPS
    fi
    # currently hard coded envs, need to parse App of Apps for each overlay dev, stage, prod
    for component in components/* 
    do 
        ktry $component $TAG_DIR  
        ktry $component/staging $TAG_DIR  
        ktry $component/staging/stone-stg-rh01 $TAG_DIR  
        ktry $component/staging/stone-stg-m01 $TAG_DIR   
    done
    echo
}
 
TAG_CURRENT=$(git rev-parse --short HEAD)
generateManifests  $TAG_CURRENT
git checkout HEAD^ >/dev/null 2>&1
TAG_PREV=$(git rev-parse --short HEAD)
generateManifests $TAG_PREV

DIR_CURRENT=$(realpath $CACHE_DIR/tag-$TAG_CURRENT)
DIR_PREV=$(realpath $CACHE_DIR/tag-$TAG_PREV)

echo "TAG $TAG_CURRENT in $DIR_CURRENT" 
echo "TAG $TAG_PREV in $DIR_PREV"  

mkdir -p $COMPARE_DIR  
DIFF_FILE=$COMPARE_DIR/diff-$TAG_PREV-$TAG_CURRENT
KDIFF=$(realpath $DIFF_FILE-kustomize)  
GDIFF=$(realpath  $DIFF_FILE-git)
diff -r $DIR_CURRENT $DIR_PREV >$KDIFF
git diff $TAG_PREV...$TAG_CURRENT > $GDIFF

echo "Diff size for kustomize: $(wc -l $KDIFF)"
echo "Diff size for git: $(wc -l $GDIFF)" 
echo 
