apiVersion: v1
kind: Namespace
metadata:
  labels:
    argocd.argoproj.io/managed-by: openshift-gitops
  name: build-templates
spec:
  finalizers:
  - kubernetes
---
apiVersion: v1
kind: Namespace
metadata:
  name: build-templates-e2e
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: admin-buildpipelineselectors
  namespace: build-templates-e2e
rules:
- apiGroups:
  - appstudio.redhat.com
  resources:
  - buildpipelineselectors
  verbs:
  - create
  - delete
  - get
  - list
  - patch
  - update
  - watch
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: edit-namespace
  namespace: build-templates-e2e
rules:
- apiGroups:
  - ""
  resources:
  - namespaces
  verbs:
  - update
  - patch
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: cm-reader
rules:
- apiGroups:
  - ""
  resources:
  - configmaps
  verbs:
  - list
  - get
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: admin-buildpipelineselectors-from-tekton-ci-namespace
  namespace: build-templates-e2e
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: admin-buildpipelineselectors
subjects:
- kind: ServiceAccount
  name: pipeline
  namespace: tekton-ci
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: edit-pipeline-from-build-templates
  namespace: build-templates-e2e
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: edit
subjects:
- kind: ServiceAccount
  name: pipeline
  namespace: tekton-ci
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: edit-pipeline-from-build-templates-namespace
  namespace: build-templates-e2e
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: edit-namespace
subjects:
- kind: ServiceAccount
  name: pipeline
  namespace: tekton-ci
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: cm-reader
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: cm-reader
subjects:
- apiGroup: rbac.authorization.k8s.io
  kind: Group
  name: system:authenticated
---
apiVersion: v1
data:
  default_build_bundle: quay.io/redhat-appstudio-tekton-catalog/pipeline-docker-build:c21fb3956e9ecfc76c293f05501d5437aebe394f
  hacbs_build_bundle: quay.io/redhat-appstudio-tekton-catalog/pipeline-docker-build:c21fb3956e9ecfc76c293f05501d5437aebe394f
kind: ConfigMap
metadata:
  name: build-pipelines-defaults
  namespace: build-templates
