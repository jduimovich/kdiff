apiVersion: v1
kind: ServiceAccount
metadata:
  annotations:
    serviceaccounts.openshift.io/oauth-redirectreference.primary: '{"kind":"OAuthRedirectReference","apiVersion":"v1","reference":{"kind":"Route","name":"quality-frontend-route"}}'
  name: dashboard-proxy
---
apiVersion: v1
data:
  BACKEND_ROUTE: https://quality-backend-route-quality-dashboard.apps.appstudio-stage.x99m.p1.openshiftapps.com
kind: ConfigMap
metadata:
  name: quality-dashboard-configmap-7bb46468bg
---
apiVersion: v1
kind: Service
metadata:
  labels:
    app.kubernetes.io/component: quality-backend
    app.kubernetes.io/instance: quality-dashboard
    app.kubernetes.io/name: quality-dashboard
  name: quality-backend-service
spec:
  internalTrafficPolicy: Cluster
  ipFamilies:
  - IPv4
  ipFamilyPolicy: SingleStack
  ports:
  - name: http
    port: 8000
    protocol: TCP
    targetPort: 8000
  selector:
    app.kubernetes.io/component: quality-backend
    app.kubernetes.io/instance: quality-dashboard
    app.kubernetes.io/name: quality-dashboard
---
apiVersion: v1
kind: Service
metadata:
  annotations:
    service.alpha.openshift.io/serving-cert-secret-name: proxy-tls
  name: quality-frontend-service
spec:
  ports:
  - name: https
    port: 443
    targetPort: 8443
  selector:
    app.kubernetes.io/component: quality-frontend
    app.kubernetes.io/instance: quality-dashboard
    app.kubernetes.io/name: quality-dashboard
---
apiVersion: apps/v1
kind: Deployment
metadata:
  labels:
    app: quality-dashboard
    app.kubernetes.io/component: quality-backend
    app.kubernetes.io/instance: quality-dashboard
    app.kubernetes.io/name: quality-dashboard
    component: quality-backend
  name: quality-backend-dashboard
spec:
  replicas: 1
  selector:
    matchLabels:
      app: quality-dashboard
      component: quality-backend
  template:
    metadata:
      labels:
        app: quality-dashboard
        app.kubernetes.io/component: quality-backend
        app.kubernetes.io/instance: quality-dashboard
        app.kubernetes.io/name: quality-dashboard
        component: quality-backend
    spec:
      containers:
      - args:
        - --port=8000
        command:
        - /root/server-runtime
        env:
        - name: MODE_SSL
          value: disable
        - name: MAX_CONNECTIONS
          value: "100"
        - name: POSTGRES_ENT_HOST
          valueFrom:
            secretKeyRef:
              key: rds-endpoint
              name: quality-dashboard-secrets
        - name: POSTGRES_ENT_DATABASE
          valueFrom:
            secretKeyRef:
              key: storage-database
              name: quality-dashboard-secrets
        - name: POSTGRES_ENT_PASSWORD
          valueFrom:
            secretKeyRef:
              key: storage-password
              name: quality-dashboard-secrets
        - name: POSTGRES_ENT_USER
          valueFrom:
            secretKeyRef:
              key: storage-user
              name: quality-dashboard-secrets
        - name: GITHUB_TOKEN
          valueFrom:
            secretKeyRef:
              key: github-token
              name: quality-dashboard-secrets
        - name: JIRA_TOKEN
          valueFrom:
            secretKeyRef:
              key: jira-token
              name: quality-dashboard-secrets
        image: quay.io/redhat-appstudio/quality-dashboard-backend:00b4fcbfee90cf4edb5eb332467648dfed031ad3
        imagePullPolicy: Always
        name: quality-backend-dashboard
        ports:
        - containerPort: 8000
          name: http
          protocol: TCP
        resources:
          limits:
            cpu: 500m
            memory: 1Gi
          requests:
            cpu: 200m
            memory: 512Mi
        securityContext:
          capabilities:
            drop:
            - ALL
      restartPolicy: Always
      terminationGracePeriodSeconds: 30
---
apiVersion: apps/v1
kind: Deployment
metadata:
  labels:
    app: quality-dashboard
    app.kubernetes.io/component: quality-frontend
    app.kubernetes.io/instance: quality-dashboard
    app.kubernetes.io/name: quality-dashboard
    component: quality-frontend
  name: quality-frontend-dashboard
spec:
  replicas: 1
  selector:
    matchLabels:
      app: quality-dashboard
      component: quality-frontend
  template:
    metadata:
      labels:
        app: quality-dashboard
        app.kubernetes.io/component: quality-frontend
        app.kubernetes.io/instance: quality-dashboard
        app.kubernetes.io/name: quality-dashboard
        component: quality-frontend
    spec:
      containers:
      - args:
        - --https-address=:8443
        - --provider=openshift
        - --openshift-service-account=dashboard-proxy
        - --upstream=http://localhost:8080
        - --tls-cert=/etc/tls/private/tls.crt
        - --tls-key=/etc/tls/private/tls.key
        - --cookie-secret=SECRET
        - --cookie-refresh=0
        - --custom-templates-dir=/usr/templates
        - --htpasswd-file=/tmp/auth/users.htpasswd
        image: quay.io/redhat-appstudio-qe/dashboard-oauth-proxy:f8a6c9973cb9c08a03cb227b65a75a0e80cea340
        imagePullPolicy: Always
        name: dashboard-proxy
        ports:
        - containerPort: 8443
          name: public
        resources:
          limits:
            cpu: 500m
            memory: 256Mi
          requests:
            cpu: 100m
            memory: 100Mi
        volumeMounts:
        - mountPath: /etc/tls/private
          name: proxy-tls
        - mountPath: /tmp/auth
          name: quality-dashboard-auth
      - env:
        - name: REACT_APP_API_SERVER_URL
          valueFrom:
            configMapKeyRef:
              key: BACKEND_ROUTE
              name: quality-dashboard-configmap-7bb46468bg
        image: quay.io/redhat-appstudio/quality-dashboard-frontend:00b4fcbfee90cf4edb5eb332467648dfed031ad3
        imagePullPolicy: Always
        name: quality-frontend-dashboard
        ports:
        - containerPort: 8080
          name: http
          protocol: TCP
        resources:
          limits:
            cpu: 500m
            memory: 256Mi
          requests:
            cpu: 100m
            memory: 32Mi
      restartPolicy: Always
      serviceAccountName: dashboard-proxy
      terminationGracePeriodSeconds: 30
      volumes:
      - name: proxy-tls
        secret:
          secretName: proxy-tls
      - name: quality-dashboard-auth
        secret:
          defaultMode: 420
          secretName: quality-dashboard-auth
---
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  annotations:
    argocd.argoproj.io/sync-options: SkipDryRunOnMissingResource=true
    argocd.argoproj.io/sync-wave: "1"
  name: quality-dashboard-secrets
  namespace: quality-dashboard
spec:
  dataFrom:
  - extract:
      key: staging/qe/quality-dashboard-secrets
  refreshInterval: 1h
  secretStoreRef:
    kind: ClusterSecretStore
    name: appsre-stonesoup-vault
  target:
    creationPolicy: Owner
    deletionPolicy: Delete
    name: quality-dashboard-secrets
---
apiVersion: route.openshift.io/v1
kind: Route
metadata:
  name: quality-backend-route
spec:
  port:
    targetPort: 8000
  tls:
    termination: edge
  to:
    kind: Service
    name: quality-backend-service
---
apiVersion: route.openshift.io/v1
kind: Route
metadata:
  name: quality-frontend-route
spec:
  port:
    targetPort: https
  tls:
    termination: reencrypt
  to:
    kind: Service
    name: quality-frontend-service
